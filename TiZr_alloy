import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from pymatgen.ext.matproj import MPRester



# Initialize MPRester with your API key
API_KEY = "D2aWXHQLGmUxtSNhNQahVlxGUtMAvYTJ"
mpr = MPRester(API_KEY)
# Query for Ti-Zr alloy data
criteria = {"elements": {"$all": ["Ti", "Zr"]}, "nelements": 2}
properties = ["material_id", "formula_pretty", "formation_energy_per_atom", "band_gap", "density"]
results = mpr.query(criteria=criteria, properties=properties)
# Convert results to a DataFrame
df = pd.DataFrame(results)
# Display the first few rows of the DataFrame
print(df.head())
# Plot formation energy per atom vs. band gap
plt.figure(figsize=(10, 6))
sns.scatterplot(data=df, x="formation_energy_per_atom", y="band_gap", hue="formula_pretty", palette="viridis")
plt.title("Formation Energy per Atom vs. Band Gap for Ti-Zr Alloys")
plt.xlabel("Formation Energy per Atom (eV)")
plt.ylabel("Band Gap (eV)")     